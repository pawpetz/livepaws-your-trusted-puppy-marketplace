{
  // D1 binding for LivePaws. This declares that the Worker should have
  // access to a D1 database as `env.DB` — but the actual database doesn't
  // exist until you create it (see the steps in D1_SETUP.md).
  //
  // "database_id" below is a placeholder. Replace it with the real ID
  // `wrangler d1 create` gives you.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "livepaws-db",
      "database_id": "REPLACE_ME_AFTER_RUNNING_WRANGLER_D1_CREATE"
    }
  ]
}
